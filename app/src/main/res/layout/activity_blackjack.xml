<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:padding="16dp">

    <TextView
        android:id="@+id/btnBackBlackjack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBlackjackTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blackjack"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackBlackjack" />

    <TextView
        android:id="@+id/tvBalanceBlackjack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Balance: $5000"
        android:textColor="#D1D5DB"
        android:textSize="18sp"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvBlackjackTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvDealerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dealer"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvBalanceBlackjack"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvDealerTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total: 0"
        android:textColor="#D1D5DB"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/tvDealerLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/dealerCardScroll"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="8dp"
        android:background="#1F2937"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDealerLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/dealerCardContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvPlayerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/dealerCardScroll"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvPlayerTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total: 0"
        android:textColor="#D1D5DB"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/tvPlayerLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/playerCardScroll"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="8dp"
        android:background="#1F2937"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvPlayerLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/playerCardContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvGameStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Enter a wager and press Deal"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/playerCardScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etWager"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:background="#FFFFFF"
        android:hint="Wager"
        android:inputType="number"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textColor="#111111"
        android:textColorHint="#666666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvGameStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnQuick100" />

    <Button
        android:id="@+id/btnQuick100"
        android:layout_width="95dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:text="$100"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/etWager"
        app:layout_constraintEnd_toStartOf="@id/btnQuick500" />

    <Button
        android:id="@+id/btnQuick500"
        android:layout_width="95dp"
        android:layout_height="50dp"
        android:text="$500"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/etWager"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/actionButtonRow"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etWager"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnHit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Hit"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnStand"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Stand"
            android:textAllCaps="false" />

    </LinearLayout>

    <Button
        android:id="@+id/btnDeal"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Deal"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/actionButtonRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>