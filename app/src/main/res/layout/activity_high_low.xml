<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:padding="16dp">

    <TextView
        android:id="@+id/btnBackHighLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHighLowTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="High-Low"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBackHighLow" />

    <TextView
        android:id="@+id/tvBalanceHighLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Balance: $5000"
        android:textColor="#D1D5DB"
        android:textSize="18sp"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvHighLowTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvRoundInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter a wager and press Start"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvBalanceHighLow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCashoutValue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Current Cashout: $0"
        android:textColor="#D1D5DB"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoundInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/cardScrollHighLow"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:layout_marginTop="14dp"
        android:background="#1F2937"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvCashoutValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/cardContainerHighLow"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <EditText
        android:id="@+id/etHighLowWager"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="8dp"
        android:background="#FFFFFF"
        android:hint="Wager"
        android:inputType="number"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textColor="#111111"
        android:textColorHint="#666666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/cardScrollHighLow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnHighLow100" />

    <Button
        android:id="@+id/btnHighLow100"
        android:layout_width="95dp"
        android:layout_height="52dp"
        android:layout_marginEnd="8dp"
        android:text="$100"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/etHighLowWager"
        app:layout_constraintEnd_toStartOf="@id/btnHighLow500" />

    <Button
        android:id="@+id/btnHighLow500"
        android:layout_width="95dp"
        android:layout_height="52dp"
        android:text="$500"
        android:textAllCaps="false"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/etHighLowWager"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/choiceRowOne"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etHighLowWager"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnChoiceOne"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Red"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnChoiceTwo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Black"
            android:textAllCaps="false" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/choiceRowTwo"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/choiceRowOne"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnChoiceThree"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Hearts"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnChoiceFour"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Spades"
            android:textAllCaps="false" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomButtonRow"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/choiceRowTwo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnCashOut"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Cash Out"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnStartHighLow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Start"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>